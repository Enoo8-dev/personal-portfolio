<button
  id="theme-toggle"
  class="inline-flex items-center justify-center rounded-lg p-2.5 text-sm text-slate-500 hover:bg-slate-100 focus:outline-none focus:ring-2 focus:ring-slate-200 dark:text-slate-400 dark:hover:bg-slate-700 dark:focus:ring-slate-700 transition-colors cursor-pointer"
  aria-label="Toggle Dark Mode"
>
  <!-- Icona Sole (visibile solo in dark mode) -->
  <span class="material-symbols-outlined !hidden dark:!block">light_mode</span>
  
  <!-- Icona Luna (visibile solo in light mode) -->
  <span class="material-symbols-outlined !block dark:!hidden">dark_mode</span>
</button>

<script>
  const themeToggleBtn = document.getElementById('theme-toggle');

  // Funzione per gestire il click
  themeToggleBtn?.addEventListener('click', () => {
    const html = document.documentElement;
    
    // Se ha la classe dark, la togliamo, altrimenti la mettiamo
    if (html.classList.contains('dark')) {
      html.classList.remove('dark');
      localStorage.setItem('theme-portfolio', 'light');
    } else {
      html.classList.add('dark');
      localStorage.setItem('theme-portfolio', 'dark');
    }
  });
</script>