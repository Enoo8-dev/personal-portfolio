---
// 1. Rimuovi l'import di astro:content e usa il tuo tipo personalizzato
// import type { CollectionEntry } from "astro:content"; <--- CANCELLA QUESTO
import type { Project } from "../../lib/wp"; // <--- AGGIUNGI QUESTO
import { Image } from "astro:assets";

interface Props {
  // 2. Aggiorna il tipo atteso
  project: Project;
  className?: string;
}

const { project, className = "" } = Astro.props;
---

<div 
  class={`project-card group relative aspect-[4/5] ${className}`}
  data-tags={JSON.stringify(project.data.tags)}
>
  
  {/* aura viola */}
  <div
    class="absolute -inset-0.5 bg-gradient-to-r from-primary to-purple-600 rounded-2xl blur opacity-0 group-hover:opacity-50 transition duration-500 group-hover:duration-200"
  >
  </div>

  {/* card */}
  <article 
    class="relative h-full w-full rounded-2xl overflow-hidden shadow-2xl bg-slate-900 isolate"
    style="transform: translateZ(0);" 
  >
    {/* imagine di sfondo */}
    <!-- <div
      class="absolute inset-0 z-0 bg-cover bg-center transition-transform duration-700 group-hover:scale-110 opacity-90 blur-[2px]"
      style={`background-image: url('${project.data.image}'); transform: translateZ(0);`}
    >
    </div> -->
    <Image
      src={project.data.image}
      alt={project.data.title}
      width={800}    
      inferSize={true} 
      format="webp"  
      class="absolute inset-0 z-0 w-full h-full object-cover transition-transform duration-700 group-hover:scale-110 opacity-90 blur-[2px]"
      style="transform: translateZ(0);"
    />

    {/* overlay scuro */}
    <div
      class="absolute inset-0 z-10 bg-gradient-to-t from-slate-950 via-slate-950/80 to-transparent"
      style="transform: translateZ(0);"
    >
    </div>

    {/* contenuto */}
    <div class="relative z-20 h-full flex flex-col justify-end p-6 sm:p-8">
      {/* tags visivi  */}
      <div class="flex flex-wrap gap-2 mb-4">
        {
          project.data.tags.slice(0, 3).map((tag: string) => (
            <span class="px-3 py-1 bg-white/10 backdrop-blur-md rounded-md text-[10px] uppercase font-bold tracking-widest text-primary-300 border border-white/10 text-white">
              {tag}
            </span>
          ))
        }
      </div>

      <h3 class="text-3xl font-bold mb-3 tracking-tight text-white">
        {project.data.title}
      </h3>

      <p class="text-slate-300 text-sm leading-relaxed mb-8 line-clamp-3">
        {project.data.description}
      </p>

      <div class="flex gap-4 mt-auto">
        {
          project.data.repo && (
            <a
              href={project.data.repo}
              target="_blank"
              class="flex-1 bg-white/10 backdrop-blur-md border border-white/20 text-white transition-all duration-300 hover:bg-white/20 hover:-translate-y-0.5 py-3 rounded-lg flex items-center justify-center gap-2 cursor-pointer no-underline"
            >
              <span class="material-symbols-outlined text-lg">code</span>
              <span class="text-xs font-bold uppercase tracking-widest">Code</span>
            </a>
          )
        }

        {
          project.data.link && (
            <a
              href={project.data.link}
              target="_blank"
              class="flex-1 bg-white/10 backdrop-blur-md border border-white/20 text-white transition-all duration-300 hover:bg-white/20 hover:-translate-y-0.5 py-3 rounded-lg flex items-center justify-center gap-2 cursor-pointer no-underline"
            >
              <span class="material-symbols-outlined text-lg">arrow_outward</span>
              <span class="text-xs font-bold uppercase tracking-widest">Live</span>
            </a>
          )
        }
      </div>
    </div>
  </article>
</div>