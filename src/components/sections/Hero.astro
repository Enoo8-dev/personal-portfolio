---
import { useTranslations } from '../../i18n/utils';
import { Image } from "astro:assets";
import meImage from '../../assets/images/avatar.png';

interface Props {
  lang: 'en' | 'it';
}

const { lang } = Astro.props;
const t = useTranslations(lang);
---

<style>
  /* Personalizzazione Scrollbar per l'area About */
  #view-about .overflow-auto::-webkit-scrollbar {
    width: 8px;
    height: 8px;
  }

  #view-about .overflow-auto::-webkit-scrollbar-track {
    background: #1e1e1e; /* Colore dello sfondo */
  }

  #view-about .overflow-auto::-webkit-scrollbar-thumb {
    background-color: #3f3f46; /* Colore della barra */
    border-radius: 20px; /* Bordi arrotondati */
    border: 2px solid #1e1e1e; /* Effetto padding attorno alla barra */
  }

  #view-about .overflow-auto::-webkit-scrollbar-thumb:hover {
    background-color: #71717b; /* Colore più chiaro all'hover */
  }
  #view-about .overflow-auto {
    scrollbar-width: thin;
    scrollbar-color: #3f3f46 #1e1e1e;
  }

  @keyframes gradient-wave {
    0% {
      background-position: 0% 50%;
    }
    50% {
      background-position: 100% 50%;
    }
    100% {
      background-position: 0% 50%;
    }
  }

  .animate-gradient-border {
    background-size: 200% 200%;
    animation: gradient-wave 5s ease infinite;
  }
</style>

<section class="w-full max-w-[1200px] px-4 py-12 md:py-24 sm:px-10" id="about">
  <div class="@container">
    <div class="flex flex-col gap-10 lg:flex-row lg:items-center">
      <div class="flex flex-col gap-6 lg:w-1/2 lg:pr-10">
        <div class="flex flex-col gap-4 text-left">
          <div
            class="inline-flex items-center gap-2 px-3 py-1 rounded-full bg-primary/5 dark:bg-primary/10 w-fit border border-primary/20"
          >
            <span class="w-2 h-2 rounded-full bg-primary animate-pulse"></span>
            <span class="text-xs font-bold text-slate-700 dark:text-slate-200 tracking-wide uppercase"
              >{t('hero.pill')}</span
            >
          </div>
          <h1
            class="text-slate-900 dark:text-white text-4xl sm:text-5xl lg:text-6xl font-black leading-tight tracking-[-0.033em] font-display"
            set:html={t('hero.title')}
          />
          <p
            class="text-slate-600 dark:text-slate-400 text-base sm:text-lg font-normal leading-relaxed max-w-[540px]"
          >
            {t('hero.subtitle')}
          </p>
        </div>
        <div class="flex flex-wrap gap-4 pt-2">
          <a
            class="flex min-w-[120px] cursor-pointer items-center justify-center overflow-hidden rounded-lg h-12 px-6 bg-primary hover:bg-primary/90 transition-colors text-white text-base font-bold leading-normal tracking-[0.015em]"
            href="#projects"
          >
            {t('hero.primaryCTAText')}
          </a>
          <a
            class="flex min-w-[120px] cursor-pointer items-center justify-center overflow-hidden rounded-lg h-12 px-6 bg-transparent border border-gray-300 dark:border-border-dark hover:bg-gray-100 dark:hover:bg-surface-dark transition-colors text-slate-900 dark:text-white text-base font-bold leading-normal tracking-[0.015em]"
            href="#contact"
          >
            {t('hero.secondaryCTAText')}
          </a>
        </div>
      </div>
      <div class="lg:w-1/2 mt-8 lg:mt-0 relative group">
        <div class="relative group w-full max-w-3xl mx-auto">
          <div
            class="absolute -inset-4 bg-gradient-to-r from-primary via-purple-600 to-primary rounded-3xl blur-2xl opacity-30 group-hover:opacity-50 transition duration-1000 group-hover:duration-200 animate-gradient-border"
          >
          </div>

          <div
            class="relative w-full h-[500px] md:h-auto md:aspect-[4/3] bg-gray-900 rounded-xl overflow-hidden shadow-2xl border border-gray-800 flex flex-col"
          >
            <div
              class="h-8 bg-[#1e293b] flex items-center px-4 border-b border-gray-800 shrink-0 z-20"
            >
              <div class="flex gap-2 group/btns cursor-pointer" id="close-btn">
                <div
                  class="w-3 h-3 rounded-full bg-red-500 flex items-center justify-center border border-red-600"
                >
                  <svg
                    class="w-2 h-2 text-black opacity-0 group-hover/btns:opacity-100 transition-opacity"
                    viewBox="0 0 24 24"
                    fill="none"
                    stroke="currentColor"
                    stroke-width="3"
                    stroke-linecap="round"
                    stroke-linejoin="round"
                    ><line x1="18" y1="6" x2="6" y2="18"></line><line
                      x1="6"
                      y1="6"
                      x2="18"
                      y2="18"></line></svg
                  >
                </div>
                <div
                  class="w-3 h-3 rounded-full bg-yellow-400 flex items-center justify-center border border-yellow-500"
                >
                </div>
                <div
                  class="w-3 h-3 rounded-full bg-green-500 flex items-center justify-center border border-green-600"
                >
                </div>
              </div>
              <span
                class="ml-4 text-xs text-gray-400 font-mono"
                id="window-title">~/portfolio/desktop</span
              >
            </div>

            <div
              class="relative w-full h-full bg-slate-950 p-4 md:p-6 overflow-hidden"
              id="desktop-area"
            >
              <div
                class="absolute inset-0 opacity-10"
                style="background-image: radial-gradient(#4f4f4f 1px, transparent 1px); background-size: 20px 20px;"
              >
              </div>

              <div
                id="view-desktop"
                class="grid grid-cols-1 gap-6 w-24 transition-all duration-300"
              >
                <button
                  data-target="me"
                  class="app-icon group flex flex-col items-center gap-2 focus:outline-none cursor-pointer"
                >
                  <div
                    class="w-16 h-16 bg-blue-500/20 rounded-xl flex items-center justify-center border border-blue-500/30 group-hover:bg-blue-500/40 transition-all backdrop-blur-sm shadow-lg group-hover:scale-105"
                  >
                    <span class="text-3xl">👨‍💻</span>
                  </div>
                  <span
                    class="text-white text-xs font-medium bg-black/40 px-2 py-0.5 rounded-full backdrop-blur-md"
                    >Me</span
                  >
                </button>

                <button
                  data-target="about"
                  class="app-icon group flex flex-col items-center gap-2 focus:outline-none cursor-pointer"
                >
                  <div
                    class="w-16 h-16 bg-yellow-500/20 rounded-xl flex items-center justify-center border border-yellow-500/30 group-hover:bg-yellow-500/40 transition-all backdrop-blur-sm shadow-lg group-hover:scale-105"
                  >
                    <svg
                      class="w-8 h-8 text-yellow-400"
                      fill="none"
                      stroke="currentColor"
                      viewBox="0 0 24 24"
                      ><path
                        stroke-linecap="round"
                        stroke-linejoin="round"
                        stroke-width="2"
                        d="M10 20l4-16m4 4l4 4-4 4M6 16l-4-4 4-4"></path></svg
                    >
                  </div>
                  <span
                    class="text-white text-xs font-medium bg-black/40 px-2 py-0.5 rounded-full backdrop-blur-md"
                    >About.json</span
                  >
                </button>
              </div>

              <div
                id="view-me"
                class="absolute inset-0 flex items-center justify-center bg-slate-900/90 backdrop-blur-sm opacity-0 pointer-events-none transition-all duration-300 scale-95 transform"
              >
                <div class="text-center">
                  <div class="relative w-32 md:w-32 mx-auto mb-4 drop-shadow-2xl">
                    
                    <Image 
                      src={meImage} 
                      alt="Federico Benini" 
                      class="w-full h-auto block"
                      widths={[240, 540, 832]} 
                      sizes="(max-width: 768px) 240px, (max-width: 1024px) 540px, 832px"
                    />

                    <svg
                      class="absolute top-0 left-0 w-full h-full pointer-events-none"
                      xmlns="http://www.w3.org/2000/svg"
                      viewBox="0 0 624 936"
                    >
                      <defs>
                        <style>
                          .cls-1 { fill: #492201; }
                          .cls-2 { fill: #210e00; }
                          .cls-3 { fill: #f2f2f2; }
                          .cls-4 { fill: url(#Sfumatura_senza_nome_199); }
                          .cls-5 { fill: url(#Sfumatura_senza_nome_234); }
                          .cls-6 { fill: url(#Sfumatura_senza_nome_139); }
                        </style>
                        <radialGradient id="Sfumatura_senza_nome_139" cx="298.977" cy="493.179" fx="298.977" fy="493.179" r="36.197" gradientUnits="userSpaceOnUse">
                          <stop offset="0" stop-color="#fff"></stop>
                          <stop offset="1" stop-color="#d6bac2"></stop>
                        </radialGradient>
                        <linearGradient id="Sfumatura_senza_nome_234" x1="288.739" y1="495.913" x2="322.391" y2="495.913" gradientUnits="userSpaceOnUse">
                          <stop offset="0" stop-color="#210000"></stop>
                          <stop offset="1" stop-color="#000"></stop>
                        </linearGradient>
                        <radialGradient id="Sfumatura_senza_nome_199" cx="462.892" cy="484.304" fx="462.892" fy="484.304" r="36.197" gradientUnits="userSpaceOnUse">
                          <stop offset="0" stop-color="#f4f4f4"></stop>
                          <stop offset="1" stop-color="#d2bac2"></stop>
                        </radialGradient>
                      </defs>

                      <g id="Occhi">
                        <g id="eye-group">
                          <path class="cls-6" d="M339.348,494.739c1.887,14.77-17.425,30.192-40.435,29.739-21.319-.42-40.435-17.041-40.435-31.304s20.938-31.304,42.261-31.304,36.801,18.721,38.609,32.87Z"></path>
                          <g id="pupil" class="pupil">
                            <path class="cls-1" d="M328.391,495.726c-.887,13.947-10.738,27.726-23.128,27.726s-25.304-13.677-25.304-27.652,11.619-27.296,24-27.783c13.588-.534,25.348,13.326,24.433,27.709Z"></path>
                            <circle class="cls-5" cx="305.565" cy="495.913" r="16.826"></circle>
                            <circle class="cls-3" cx="295.065" cy="485.804" r="5.283"></circle>
                          </g>
                        </g>
                        <g id="eye-group-2" data-name="eye-group">
                          <path class="cls-4" d="M422.521,485.865c-1.887,14.77,17.425,30.192,40.435,29.739,21.319-.42,40.435-17.041,40.435-31.304s-20.938-31.304-42.261-31.304-36.801,18.721-38.609,32.87Z"></path>
                          <g id="pupil-2" data-name="pupil" class="pupil">
                            <path class="cls-1" d="M482.063,487.694c-.887,13.947-10.738,27.726-23.128,27.726s-25.304-13.677-25.304-27.652,11.619-27.296,24-27.783c13.588-.534,25.348,13.326,24.433,27.709Z"></path>
                            <circle class="cls-2" cx="457.783" cy="487.957" r="16.826"></circle>
                            <circle class="cls-3" cx="448.326" cy="477.457" r="5.283"></circle>
                          </g>
                        </g>
                      </g>
                    </svg>
                  </div>
                  
                  <h2 class="text-2xl font-bold text-white mb-2">
                    {t('hero.window.me.title')} 👋
                  </h2>
                  <p class="text-gray-400 text-sm max-w-xs mx-auto">
                    {t('hero.window.me.subtitle')}
                  </p>
                  <button
                    class="close-app mt-6 mb-6 px-4 py-2 bg-white text-black rounded-full text-sm font-bold hover:bg-gray-200 transition cursor-pointer"
                    >{t('hero.window.me.button')}
                  </button>
                </div>
              </div>

              <div
                id="view-about"
                class="absolute inset-0 bg-[#1e1e1e] opacity-0 pointer-events-none transition-all duration-300 transform translate-y-4 font-mono z-10 overflow-hidden flex flex-col"
              >
                <div
                  class="flex bg-[#252526] text-gray-400 text-xs shrink-0 border-b border-black/20"
                >
                  <div
                    class="px-4 py-2 bg-[#1e1e1e] text-white border-t-2 border-blue-500 flex items-center gap-2"
                  >
                    <span class="text-yellow-400">&#123;&#125;</span>
                    <span class="opacity-90">about.json</span>
                    <span
                      class="ml-2 hover:bg-gray-700 rounded-sm px-1 cursor-pointer close-app transition-colors"
                      >x</span
                    >
                  </div>
                </div>

                <div
                  class="p-4 md:p-6 overflow-auto text-gray-300 h-full text-xs md:text-sm"
                >
                  <div class="flex min-w-max">
                    <div
                      class="text-gray-600 select-none text-right pr-2 md:pr-4 border-r border-gray-700 mr-2 md:mr-4 font-mono leading-6 opacity-50"
                    >
                      1<br />2<br />3<br />4<br />5<br />6<br />7<br />8<br
                      />9<br />10<br />11<br />12<br />13
                    </div>

                  <pre class="font-mono leading-6"><code><span class="text-yellow-400">&#123;</span>
    <span class="text-sky-400">"name"</span>: <span class="text-orange-400">"Federico Benini"</span>,
    <span class="text-sky-400">"role"</span>: <span class="text-orange-400">"{t('hero.window.about.role')}"</span>,
    <span class="text-sky-400">"location"</span>: <span class="text-orange-400">"Italy"</span>,
    <span class="text-sky-400">"skills"</span>: <span class="text-pink-400">[</span>
        <span class="text-orange-400">"Astro"</span>,
        <span class="text-orange-400">"Angular"</span>,
        <span class="text-orange-400">"Tailwind"</span>,
        <span class="text-orange-400">"UI/UX Design"</span>
    <span class="text-pink-400">]</span>,
    <span class="text-sky-400">"status"</span>: <span class="text-orange-400">"{t('hero.window.about.status')}"</span>,
    <span class="text-sky-400">"coffee_level"</span>: <span class="text-purple-400">99.9</span>
<span class="text-yellow-400">&#125;</span></code></pre>
                  </div>
                </div>
              </div>
            </div>
          </div>
        </div>
      </div>
    </div>
  </div>
</section>

<script>
  // Logica per gestire le "App" e gli occhi
  const icons = document.querySelectorAll('.app-icon');
  const closeBtns = document.querySelectorAll('.close-app');
  const redBtn = document.getElementById('close-btn');

  // Views
  const views = {
    desktop: document.getElementById('view-desktop'),
    me: document.getElementById('view-me'),
    about: document.getElementById('view-about'),
  };

  const title = document.getElementById('window-title');

  // 1. Apertura App
  icons.forEach((icon) => {
    icon.addEventListener('click', () => {
      const target = icon.dataset.target;

      // Nascondi icone desktop
      views.desktop.classList.add(
        'opacity-0',
        'scale-90',
        'pointer-events-none',
      );

      // Mostra app target
      if (target === 'me') {
        views.me.classList.remove(
          'opacity-0',
          'pointer-events-none',
          'scale-95',
        );
        title.innerText = '~/portfolio/me';
      } else if (target === 'about') {
        views.about.classList.remove(
          'opacity-0',
          'pointer-events-none',
          'translate-y-4',
        );
        title.innerText = '~/portfolio/about-me';
      }
    });
  });

  // 2. Chiusura App (Torna al Desktop)
  function closeAll() {
    // Reset Views
    views.me.classList.add('opacity-0', 'pointer-events-none', 'scale-95');
    views.about.classList.add(
      'opacity-0',
      'pointer-events-none',
      'translate-y-4',
    );

    // Mostra Desktop
    views.desktop.classList.remove(
      'opacity-0',
      'scale-90',
      'pointer-events-none',
    );
    title.innerText = '~/portfolio/desktop';
  }

  closeBtns.forEach((btn) => btn.addEventListener('click', closeAll));
  redBtn?.addEventListener('click', closeAll);

  // 3. Eye Tracking Logic
  document.addEventListener('mousemove', (e) => {
    const pupils = document.querySelectorAll('.pupil');

    pupils.forEach((pupil) => {
      // Ottieni la posizione centrale dell'occhio
      const rect = pupil.getBoundingClientRect();
      const x = rect.left + rect.width / 2;
      const y = rect.top + rect.height / 2;

      // Calcola angolo
      const radian = Math.atan2(e.pageX - x, e.pageY - y);

      // Muovi la pupilla (limitando il movimento a raggio 3px)
      const distance = Math.min(3, Math.hypot(e.pageX - x, e.pageY - y) / 10);
      const moveX = Math.sin(radian) * distance * 2.5; // Moltiplicatore per sensibilità
      const moveY = Math.cos(radian) * distance * 2.5;

      pupil.style.transform = `translate(${moveX}px, ${moveY}px)`;
    });
  });
</script>
