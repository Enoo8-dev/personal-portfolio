---
import { useTranslations } from '../../i18n/utils';

interface Props {
  lang: 'en' | 'it';
}

const { lang } = Astro.props;
const t = useTranslations(lang);
---

<section class="w-full max-w-[1200px] px-4 py-12 md:py-24 sm:px-10" id="about">
<div class="@container">
    <div class="flex flex-col gap-10 lg:flex-row lg:items-center">
        <div class="flex flex-col gap-6 lg:w-1/2 lg:pr-10">
            <div class="flex flex-col gap-4 text-left">
                <div
                    class="inline-flex items-center gap-2 px-3 py-1 rounded-full bg-primary/5 w-fit border border-primary/20">
                    <span class="w-2 h-2 rounded-full bg-primary animate-pulse"></span>
                    <span class="text-xs font-bold text-primary tracking-wide uppercase">{t('hero.pill')}</span>
                </div>
                <h1
                    class="text-slate-900 dark:text-white text-4xl sm:text-5xl lg:text-6xl font-black leading-tight tracking-[-0.033em] font-display"
                    set:html={t('hero.title')}
                >  
                </h1>
                <p
                    class="text-slate-600 dark:text-slate-400 text-base sm:text-lg font-normal leading-relaxed max-w-[540px]">
                    {t('hero.subtitle')}
                </p>
            </div>
            <div class="flex flex-wrap gap-4 pt-2">
                <a class="flex min-w-[120px] cursor-pointer items-center justify-center overflow-hidden rounded-lg h-12 px-6 bg-primary hover:bg-primary/90 transition-colors text-white text-base font-bold leading-normal tracking-[0.015em]"
                    href="#projects">
                    {t('hero.primaryCTAText')}
                </a>
                <a class="flex min-w-[120px] cursor-pointer items-center justify-center overflow-hidden rounded-lg h-12 px-6 bg-transparent border border-gray-300 dark:border-border-dark hover:bg-gray-100 dark:hover:bg-surface-dark transition-colors text-slate-900 dark:text-white text-base font-bold leading-normal tracking-[0.015em]"
                    href="#contact">
                    {t('hero.secondaryCTAText')}
                </a>
            </div>
            <!-- <div
                class="flex items-center gap-6 mt-4 pt-6 border-t border-gray-200 dark:border-border-dark">
                <div class="flex flex-col">
                    <span
                        class="text-2xl font-bold font-display text-slate-900 dark:text-white">5+</span>
                    <span
                        class="text-xs text-slate-500 dark:text-slate-400 uppercase tracking-wider">Years
                        Exp.</span>
                </div>
                <div class="w-px h-10 bg-gray-200 dark:bg-border-dark"></div>
                <div class="flex flex-col">
                    <span
                        class="text-2xl font-bold font-display text-slate-900 dark:text-white">50+</span>
                    <span
                        class="text-xs text-slate-500 dark:text-slate-400 uppercase tracking-wider">Projects</span>
                </div>
                <div class="w-px h-10 bg-gray-200 dark:bg-border-dark"></div>
                <div class="flex flex-col">
                    <span
                        class="text-2xl font-bold font-display text-slate-900 dark:text-white">20+</span>
                    <span
                        class="text-xs text-slate-500 dark:text-slate-400 uppercase tracking-wider">Clients</span>
                </div>
            </div> -->
        </div>
        <div class="lg:w-1/2 mt-8 lg:mt-0 relative group">
    <div
        class="absolute -inset-1 bg-gradient-to-r from-primary to-purple-600 rounded-2xl blur opacity-25 group-hover:opacity-50 transition duration-1000 group-hover:duration-200">
    </div>

    <div
        class="relative w-full aspect-[4/3] bg-surface-dark rounded-xl overflow-hidden shadow-2xl border border-gray-200 dark:border-border-dark">

        <div
            class="absolute top-0 left-0 w-full h-8 bg-gray-100 dark:bg-[#0d121c] flex items-center px-4 border-b border-gray-200 dark:border-border-dark">

            <div class="flex gap-2 group">

                <div class="w-3 h-3 rounded-full bg-red-500 flex items-center justify-center border border-red-600">
                    <svg class="w-2 h-2 text-black opacity-0 group-hover:opacity-100 transition-opacity" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="3" stroke-linecap="round" stroke-linejoin="round">
                        <line x1="18" y1="6" x2="6" y2="18"></line>
                        <line x1="6" y1="6" x2="18" y2="18"></line>
                    </svg>
                </div>

                <div class="w-3 h-3 rounded-full bg-yellow-400 flex items-center justify-center border border-yellow-500">
                    <svg class="w-2 h-2 text-black opacity-0 group-hover:opacity-100 transition-opacity" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="3" stroke-linecap="round" stroke-linejoin="round">
                        <line x1="5" y1="12" x2="19" y2="12"></line>
                    </svg>
                </div>

                <!-- TODO: fare bene icona full size window -->
                <div class="w-3 h-3 rounded-full bg-green-500 flex items-center justify-center border border-green-600">
                    <svg class="w-2 h-2 text-black opacity-0 group-hover:opacity-100 transition-opacity" viewBox="0 0 24 24" fill="currentColor" stroke-width="3" stroke-linecap="round" stroke-linejoin="round">
                        <path d="M15 3L21 3L21 9L15 3Z" />
                        <path d="M9 21L3 21L3 15L9 21Z" />
                    </svg>
                </div>
            </div> 
        </div>

        <div class="w-full h-full pt-8 bg-cover bg-center"
            data-alt="Code editor preview"
            style='background-image: url("https://placehold.co/600x400/orange/white");'>
            <div
                class="absolute inset-0 bg-gradient-to-t from-background-dark/80 to-transparent pt-8">
            </div>
        </div>
    </div>
</div>
    </div>
</div>
</section>