---
import { getCollection, type CollectionEntry } from "astro:content";
import { useTranslations } from "../../i18n/utils";
import ProjectCard from "../ui/ProjectCard.astro";

interface Props {
    lang: "en" | "it";
}

const { lang } = Astro.props;
const t = useTranslations(lang);

// Recupera tutti i progetti filtrati per lingua
const allProjects = await getCollection(
    "projects",
    ({ data }: { data: CollectionEntry<"projects">["data"] }) => {
        return data.lang === lang;
    },
);

const sortedProjects = allProjects.sort(
    (a: CollectionEntry<"projects">, b: CollectionEntry<"projects">) => {
        // Priorità ai progetti in evidenza
        if (a.data.featured && !b.data.featured) return -1;
        if (!a.data.featured && b.data.featured) return 1;

        // Se entrambi hanno la stessa priorità, ordina per data (più recente prima)
        return b.data.pubDate.valueOf() - a.data.pubDate.valueOf();
    }
);

// Prendi solo i primi 6 progetti
const displayedProjects = sortedProjects.slice(0, 6);

const viewAllLink = lang === 'it' ? '/it/projects' : '/projects';
---

<section
    id="projects"
    class="w-full py-20 px-4 sm:px-10 max-w-[1200px] mx-auto scroll-mt-20"
>
    <!-- Intestazione -->
    <div class="flex flex-col gap-4 mb-12">
        <h2 class="text-3xl sm:text-4xl font-bold text-slate-900 dark:text-white font-display">
            {t("projects.title")}
        </h2>
        <p class="text-lg text-slate-600 dark:text-slate-400 max-w-2xl">
            {t("projects.subtitle")}
        </p>
    </div>

    <!-- Griglia Progetti -->
    <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-8">
        {
            displayedProjects.map((project, index) => (
                <ProjectCard 
                    project={project} 
                    className={index >= 3 ? "hidden md:block" : ""}
                />
            ))
        }
    </div>

    <!-- Bottone Vedi Tutti -->
    <div class="flex justify-center mt-12">
        <a 
            href={viewAllLink}
            class="inline-flex items-center justify-center gap-2 px-8 py-4 bg-transparent border-2 border-slate-200 dark:border-border-dark hover:border-primary text-slate-900 dark:text-white hover:text-primary dark:hover:border-primary transition-all duration-300 rounded-full font-bold uppercase tracking-wider text-sm group"
        >
            {t("projects.viewall")}
            <span class="material-symbols-outlined transition-transform duration-300 group-hover:translate-x-1">
                arrow_forward
            </span>
        </a>
    </div>
</section>