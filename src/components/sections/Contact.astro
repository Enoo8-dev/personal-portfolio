---
import { useTranslations } from "../../i18n/utils";
import { personalInfo } from "../../data/business";
import MailOutlined from "../common/icons/MailOutlined.astro";
import LocationOnOutlined from "../common/icons/LocationOnOutlined.astro";
import SendOutlined from "../common/icons/SendOutlined.astro";

interface Props {
    lang: "en" | "it";
}

const { lang } = Astro.props;
const t = useTranslations(lang);

const socialLinks = [
    {
        name: "GitHub",
        href: personalInfo.social.github,
        iconPath: "M12 0c-6.626 0-12 5.373-12 12 0 5.302 3.438 9.8 8.207 11.387.599.111.793-.261.793-.577v-2.234c-3.338.726-4.033-1.416-4.033-1.416-.546-1.387-1.333-1.756-1.333-1.756-1.089-.745.083-.729.083-.729 1.205.084 1.839 1.237 1.839 1.237 1.07 1.834 2.807 1.304 3.492.997.107-.775.418-1.305.762-1.604-2.665-.305-5.467-1.334-5.467-5.931 0-1.311.469-2.381 1.236-3.221-.124-.303-.535-1.524.117-3.176 0 0 1.008-.322 3.301 1.23.957-.266 1.983-.399 3.003-.404 1.02.005 2.047.138 3.006.404 2.291-1.552 3.297-1.23 3.297-1.23.653 1.653.242 2.874.118 3.176.77.84 1.235 1.911 1.235 3.221 0 4.609-2.807 5.624-5.479 5.921.43.372.823 1.102.823 2.222v3.293c0 .319.192.694.801.576 4.765-1.589 8.199-6.086 8.199-11.386 0-6.627-5.373-12-12-12z"
    },
    {
        name: "LinkedIn",
        href: personalInfo.social.linkedin,
        iconPath: "M19 0h-14c-2.761 0-5 2.239-5 5v14c0 2.761 2.239 5 5 5h14c2.762 0 5-2.239 5-5v-14c0-2.761-2.238-5-5-5zm-11 19h-3v-11h3v11zm-1.5-12.268c-.966 0-1.75-.79-1.75-1.764s.784-1.764 1.75-1.764 1.75.79 1.75 1.764-.783 1.764-1.75 1.764zm13.5 12.268h-3v-5.604c0-3.368-4-3.113-4 0v5.604h-3v-11h3v1.765c1.396-2.586 7-2.777 7 2.476v6.759z"
    },
    {
        name: "vCard",
        href: lang === 'it' ? '/it/connect' : '/connect',
        svg: `<svg width="100%" height="100%" viewBox="0 0 64 64" fill="none" stroke="currentColor" xmlns="http://www.w3.org/2000/svg" stroke-width="4"><polyline points="44 8 44 16 52 16"></polyline><polygon points="52 16 44 8 12 8 12 56 52 56 52 16"></polygon><ellipse cx="32" cy="28" rx="6" ry="8"></ellipse><path d="M27 32.73s-5 1.34-6 4A16.42 16.42 0 0 0 20 44h24a16.42 16.42 0 0 0-1-7.27c-1-2.66-6-4-6-4"></path></svg>`,
        featured: true,
        inSite: true
    }
];
---

<style>
    .cursor-pizza {
        cursor: pointer; 
        cursor: url("data:image/svg+xml;utf8,<svg xmlns='http://www.w3.org/2000/svg' width='40' height='48' viewport='0 0 100 100' style='fill:black;font-size:24px;'><text y='50%'>🍕</text></svg>") 16 16, auto;
    }
</style>

<script is:inline src={`https://www.google.com/recaptcha/api.js?render=${import.meta.env.PUBLIC_RECAPTCHA_SITE_KEY}`}></script>

<section class="w-full bg-white dark:bg-surface-dark border-t border-gray-200 dark:border-border-dark mt-8 transition-colors" id="contact">
    <div class="w-full max-w-[1200px] px-4 py-20 sm:px-10 mx-auto">
        <div class="grid grid-cols-1 lg:grid-cols-2 gap-12 lg:gap-24">
            
            <div class="flex flex-col gap-6">
                <div>
                    <h2 class="text-slate-900 dark:text-white text-3xl sm:text-4xl font-bold leading-tight tracking-[-0.015em] font-display mb-4">
                        {t('contact.title')}
                    </h2>
                    <p class="text-slate-600 dark:text-slate-400 text-lg">
                        {t('contact.subtitle')}
                    </p>
                </div>

                <div class="flex flex-col gap-6 mt-4">
                    <div class="flex items-center gap-4 group cursor-pointer">
                        <div class="size-12 shrink-0 rounded-full bg-primary/10 flex items-center justify-center text-primary group-hover:bg-primary group-hover:text-white transition-colors duration-300">
                            <MailOutlined className="w-8 h-8" />
                        </div>
                        <div>
                            <h4 class="text-sm font-bold text-slate-500 dark:text-slate-400 uppercase tracking-wide">
                                {t('contact.email')}
                            </h4>
                            <a href={`mailto:${personalInfo.email}`} class="text-lg font-medium text-slate-900 dark:text-white hover:text-primary transition-colors">
                                {personalInfo.email}
                            </a>
                        </div>
                    </div>

                    <div class="flex items-center gap-4 group cursor-pointer cursor-pizza">
                        <div class="size-12 shrink-0 rounded-full bg-primary/10 flex items-center justify-center text-primary group-hover:bg-primary group-hover:text-white transition-colors duration-300">
                            <LocationOnOutlined className="w-8 h-8" />
                        </div>
                        <div>
                            <h4 class="text-sm font-bold text-slate-500 dark:text-slate-400 uppercase tracking-wide">
                                {t('contact.location')}
                            </h4>
                            <p class="text-lg font-medium text-slate-900 dark:text-white">
                                {personalInfo.location}
                                <span 
                                    id="local-time" 
                                    data-timezone={personalInfo.timezone}
                                    class="text-base font-normal text-slate-500 dark:text-slate-400"
                                ></span>
                            </p>
                        </div>
                    </div>
                </div>

                <div class="flex gap-4 mt-8">
                    {socialLinks.map(social => (
                        <div class="relative flex items-center justify-center">
                            {social.featured && (
                                <span class="absolute inset-0 rounded-full bg-primary/40 animate-[ping_2s_cubic-bezier(0,0,0.2,1)_infinite]"></span>
                            )}
                            <div class="absolute inset-0 rounded-full bg-white dark:bg-surface-dark"></div>
                            
                            <a 
                                aria-label={social.name}
                                class="relative z-10 size-10 rounded-full border border-gray-300 dark:border-border-dark flex items-center justify-center text-slate-600 dark:text-slate-400 hover:bg-primary hover:text-white hover:border-primary transition-all duration-300" 
                                href={social.href}
                                {...(social.inSite ? { 'data-internal-link': true } : { target: "_blank", rel: "noopener noreferrer" })}
                            >
                                {'iconPath' in social ? (
                                    <svg class="w-5 h-5 fill-current" viewBox="0 0 24 24" xmlns="http://www.w3.org/2000/svg">
                                        <path d={social.iconPath}></path>
                                    </svg>
                                ) : (
                                    <div class="w-5 h-5 flex items-center justify-center" set:html={social.svg} />
                                )}
                            </a>
                        </div>
                    ))}
                </div>
            </div>

            <div class="bg-gray-50 dark:bg-[#111722] p-8 rounded-xl border border-gray-200 dark:border-border-dark transition-colors">
                <form id="contact-form" class="flex flex-col gap-5">
                    
                    <div class="flex flex-col gap-2">
                        <label for="name" class="text-sm font-bold text-slate-700 dark:text-white font-display">
                            {t('contact.form.name')}
                        </label>
                        <input 
                            id="name"
                            name="name" 
                            required
                            class="w-full h-12 rounded-lg bg-white dark:bg-surface-dark border border-gray-300 dark:border-border-dark px-4 text-slate-900 dark:text-white placeholder-slate-400 focus:outline-none focus:ring-2 focus:ring-primary focus:border-transparent transition-all" 
                            placeholder={t('contact.form.placeholder.name')} 
                            type="text"
                            autocomplete="name"
                        />
                    </div>
                    
                    <div class="flex flex-col gap-2">
                        <label for="email" class="text-sm font-bold text-slate-700 dark:text-white font-display">
                            {t('contact.form.email')}
                        </label>
                        <input 
                            id="email"
                            name="email"
                            required
                            class="w-full h-12 rounded-lg bg-white dark:bg-surface-dark border border-gray-300 dark:border-border-dark px-4 text-slate-900 dark:text-white placeholder-slate-400 focus:outline-none focus:ring-2 focus:ring-primary focus:border-transparent transition-all" 
                            placeholder={t('contact.form.placeholder.email')} 
                            type="email"
                            autocomplete="email"
                        />
                    </div>
                    
                    <div class="flex flex-col gap-2">
                        <label for="message" class="text-sm font-bold text-slate-700 dark:text-white font-display">
                            {t('contact.form.message')}
                        </label>
                        <textarea 
                            id="message"
                            name="message"
                            required
                            class="w-full rounded-lg bg-white dark:bg-surface-dark border border-gray-300 dark:border-border-dark p-4 text-slate-900 dark:text-white placeholder-slate-400 focus:outline-none focus:ring-2 focus:ring-primary focus:border-transparent transition-all resize-none" 
                            placeholder={t('contact.form.placeholder.message')} 
                            rows="4"
                        ></textarea>
                    </div>
                    
                    <button 
                        id="submit-btn"
                        type="submit"
                        class="mt-2 w-full h-12 rounded-lg bg-primary hover:bg-primary/90 text-white font-bold text-base transition-colors flex items-center justify-center gap-2 cursor-pointer disabled:opacity-70 disabled:cursor-not-allowed"
                    >
                        <span>{t('contact.form.send')}</span>
                        <SendOutlined className="w-8 h-8 text-lg" />
                    </button>

                    <div class="mt-4 text-[10px] text-gray-400">
                        <span set:html={t('contact.form.protect')}></span>
                    </div>

                    <div id="form-status" class="hidden" role="alert"></div>
                </form>
            </div>

        </div>
    </div>
</section>

<script>
    const siteKey = import.meta.env.PUBLIC_RECAPTCHA_SITE_KEY;
    // Logica Client-Side per inviare i dati all'API
    const form = document.getElementById('contact-form') as HTMLFormElement;
    const submitBtn = document.getElementById('submit-btn') as HTMLButtonElement;
    const statusMsg = document.getElementById('form-status');

    const icons = {
      check: `<svg xmlns="http://www.w3.org/2000/svg" height="24px" viewBox="0 -960 960 960" width="24px" fill="#e3e3e3"><path d="m424-296 282-282-56-56-226 226-114-114-56 56 170 170Zm56 216q-83 0-156-31.5T197-197q-54-54-85.5-127T80-480q0-83 31.5-156T197-763q54-54 127-85.5T480-880q83 0 156 31.5T763-763q54 54 85.5 127T880-480q0 83-31.5 156T763-197q-54 54-127 85.5T480-80Zm0-80q134 0 227-93t93-227q0-134-93-227t-227-93q-134 0-227 93t-93 227q0 134 93 227t227 93Zm0-320Z"/></svg>`,
      error: `<svg xmlns="http://www.w3.org/2000/svg" height="24px" viewBox="0 -960 960 960" width="24px" fill="#e3e3e3"><path d="M508.5-291.5Q520-303 520-320t-11.5-28.5Q497-360 480-360t-28.5 11.5Q440-337 440-320t11.5 28.5Q463-280 480-280t28.5-11.5ZM440-440h80v-240h-80v240Zm40 360q-83 0-156-31.5T197-197q-54-54-85.5-127T80-480q0-83 31.5-156T197-763q54-54 127-85.5T480-880q83 0 156 31.5T763-763q54 54 85.5 127T880-480q0 83-31.5 156T763-197q-54 54-127 85.5T480-80Zm0-80q134 0 227-93t93-227q0-134-93-227t-227-93q-134 0-227 93t-93 227q0 134 93 227t227 93Zm0-320Z"/></svg>`,
      wifi_off: `<svg xmlns="http://www.w3.org/2000/svg" height="24px" viewBox="0 -960 960 960" width="24px" fill="#e3e3e3"><path d="M790-56 414-434q-47 11-87.5 33T254-346l-84-86q32-32 69-56t79-42l-90-90q-41 21-76.5 46.5T84-516L0-602q32-32 66.5-57.5T140-708l-84-84 56-56 736 736-58 56Zm-381-93.5Q380-179 380-220q0-42 29-71t71-29q42 0 71 29t29 71q0 41-29 70.5T480-120q-42 0-71-29.5ZM716-358l-29-29-29-29-144-144q81 8 151.5 41T790-432l-74 74Zm160-158q-77-77-178.5-120.5T480-680q-21 0-40.5 1.5T400-674L298-776q44-12 89.5-18t92.5-6q142 0 265 53t215 145l-84 86Z"/></svg>`
    }

    let msgTimer: ReturnType<typeof setTimeout>;

    if (form && submitBtn && statusMsg) {
        form.addEventListener('submit', (e) => {
            e.preventDefault(); 

            // Blocchiamo subito il bottone per evitare doppi click
            submitBtn.disabled = true;

            // Chiamiamo Google reCAPTCHA
            // @ts-ignore (Ignoriamo TypeScript perché grecaptcha è caricato esternamente)
            grecaptcha.ready(function() {
                // @ts-ignore
                grecaptcha.execute(siteKey, {action: 'submit'}).then(async function(token) {                    
                    if (msgTimer) {
                        clearTimeout(msgTimer);
                    }

                    const originalBtnText = submitBtn.innerHTML;
                    submitBtn.innerHTML = '<span class="animate-spin inline-block w-4 h-4 border-2 border-white border-t-transparent rounded-full"></span> Invio...';
                    
                    statusMsg.classList.add('hidden');
                    statusMsg.className = "hidden"; 

                    const formData = new FormData(form);

                    // Aggiungiamo il token al formData prima di inviare
                    formData.append('recaptcha_token', token); 

                    try {
                        const response = await fetch('/send-email.php', {
                            method: 'POST',
                            body: formData
                        });

                        const data = await response.json();

                        statusMsg.classList.remove('hidden');

                        if (response.ok) {
                            // SUCCESSO
                            statusMsg.className = "mt-4 p-4 rounded-lg bg-green-50 dark:bg-green-900/20 border border-green-200 dark:border-green-800 text-green-700 dark:text-green-300 text-sm font-medium flex items-center justify-center gap-2 animate-pulse";
                            statusMsg.innerHTML = `
                                ${icons.check}
                                <span>Messaggio inviato con successo!</span>
                            `;
                            form.reset();
                        } else {
                            // ERRORE (Backend o Spam rilevato)
                            statusMsg.className = "mt-4 p-4 rounded-lg bg-red-50 dark:bg-red-900/20 border border-red-200 dark:border-red-800 text-red-700 dark:text-red-300 text-sm font-medium flex items-center justify-center gap-2";
                            statusMsg.innerHTML = `
                                ${icons.error}
                                <span>${data.message || "Errore nell'invio."}</span>
                            `;
                        }

                        msgTimer = setTimeout(() => {
                            statusMsg.classList.add('hidden');
                        }, 30000);

                    } catch (error) {
                        statusMsg.classList.remove('hidden');
                        statusMsg.className = "mt-4 p-4 rounded-lg bg-red-50 dark:bg-red-900/20 border border-red-200 dark:border-red-800 text-red-700 dark:text-red-300 text-sm font-medium flex items-center justify-center gap-2";
                        statusMsg.innerHTML = `
                            ${icons.wifi_off}
                            <span>Errore di connessione. Riprova più tardi.</span>
                        `;
                    } finally {
                        submitBtn.disabled = false;
                        submitBtn.innerHTML = originalBtnText;
                    }
                    // --- FINE LOGICA ORIGINALE ---

                }); // Chiusura .then()
            }); // Chiusura .ready()
        });
    }

    // show time
    function updateLocalTime() {
        const timeDisplay = document.getElementById('local-time');
        
        if (timeDisplay) {
            const timeZone = timeDisplay.getAttribute('data-timezone') || 'Europe/Rome';
            const now = new Date();
            
            const options: Intl.DateTimeFormatOptions = { 
                timeZone: timeZone, 
                hour: '2-digit', 
                minute: '2-digit',
                hour12: false
            };

            try {
                const timeString = new Intl.DateTimeFormat('it-IT', options).format(now);
                timeDisplay.textContent = `(${timeString})`;
            } catch (e) {
                console.error("Invalid timezone:", timeZone);
                timeDisplay.textContent = ""; 
            }
        }
    }

    updateLocalTime();
    setInterval(updateLocalTime, 60000);
</script>