---
import { useTranslations } from '../../i18n/utils';
import ThemeToggle from "../ui/ThemeToggle.astro";
import Logo from "./Logo.astro";

interface Props {
    lang: 'en' | 'it';
}

const { lang } = Astro.props;
const t = useTranslations(lang);

const links = [
    { name: t('nav.about'), href: "#about" },
    { name: t('nav.skills'), href: "#skills" },
    { name: t('nav.projects'), href: "#projects" },
    { name: t('nav.contact'), href: "#contact" },
];

const currentPath = Astro.url.pathname;

// --- CALCOLO PATH PER IL CAMBIO LINGUA ---
const cleanPath = currentPath.startsWith('/it') ? currentPath.replace(/^\/it/, '') : currentPath;
const normalizedPath = cleanPath || '/'; 

const enLink = normalizedPath;
const itLink = normalizedPath === '/' ? '/it' : `/it${normalizedPath}`;

// --- LOGICA NAVIGAZIONE MENU ---
const homeLink = lang === 'it' ? '/it' : '/';

const getHref = (anchor: string) => {
  const pathForCheck = currentPath.endsWith('/') && currentPath.length > 1 ? currentPath.slice(0, -1) : currentPath;
  const isHome = pathForCheck === '' || pathForCheck === '/' || pathForCheck === '/it';
  
  if (isHome) {
    return anchor; 
  }
  
  return `${homeLink}${anchor}`;
};
---

<header class="sticky top-0 z-50 w-full">
    <div class="relative z-50 w-full border-b border-solid border-gray-200 dark:border-border-dark bg-background-light/80 dark:bg-background-dark/80 backdrop-blur-md">
        <div class="flex h-16 items-center justify-between px-4 sm:px-10 max-w-[1200px] mx-auto w-full">
            <a href={homeLink} class="flex items-center gap-2 text-primary dark:text-white">
                <div class="flex items-center justify-center size-8 rounded-lg bg-primary/10 dark:bg-white/10">
                    <Logo className="w-5 h-5 text-primary dark:text-white" />
                </div>
                <h2 class="text-slate-900 dark:text-white text-lg font-bold leading-tight tracking-[-0.015em] font-display">
                    Federico Benini
                </h2>
            </a>
            
            <nav class="hidden md:flex flex-1 justify-end gap-8 items-center">
                <div class="flex items-center gap-9">
                    {links.map(link => (
                        <a class="text-slate-600 dark:text-slate-300 hover:text-primary dark:hover:text-white text-sm font-medium leading-normal transition-colors"
                            href={getHref(link.href)}>
                            {link.name}
                        </a>
                    ))}
                </div>
                <div class="h-6 w-px bg-gray-300 dark:bg-border-dark mx-2"></div>
                <ThemeToggle />
                
                <div class="flex items-center gap-2 ml-2 text-sm font-medium">
                    <a 
                        href={enLink} 
                        class={`lang-switch ${lang === 'en' ? "text-primary dark:text-white pointer-events-none" : "text-slate-500 dark:text-slate-400 hover:text-primary dark:hover:text-white transition-colors"}`}
                    >
                        EN
                    </a>
                    <span class="text-slate-300 dark:text-slate-600">|</span>
                    <a 
                        href={itLink} 
                        class={`lang-switch ${lang === 'it' ? "text-primary dark:text-white pointer-events-none" : "text-slate-500 dark:text-slate-400 hover:text-primary dark:hover:text-white transition-colors"}`}
                    >
                        IT
                    </a>
                </div>
            </nav>
            
            <div class="flex items-center gap-4 md:hidden">
                <ThemeToggle />
                <div class="flex items-center gap-2 ml-2 text-sm font-medium">
                    <a
                        href={enLink} 
                        class={`lang-switch ${lang === 'en' ? "text-primary dark:text-white pointer-events-none" : "text-slate-500 dark:text-slate-400 hover:text-primary dark:hover:text-white transition-colors"}`}
                    >
                        EN
                    </a>
                    <span class="text-slate-300 dark:text-slate-600">|</span>
                    <a 
                        href={itLink} 
                        class={`lang-switch ${lang === 'it' ? "text-primary dark:text-white pointer-events-none" : "text-slate-500 dark:text-slate-400 hover:text-primary dark:hover:text-white transition-colors"}`}
                    >
                        IT
                    </a>
                </div>

                <button id="mobile-menu-btn" class="group relative z-50 p-2 text-slate-600 dark:text-slate-300 flex items-center justify-center cursor-pointer hover:bg-gray-100 dark:hover:bg-white/10 rounded-md transition-colors w-10 h-10">
                    <div class="relative w-5 h-3.5 overflow-hidden">
                        <span class="absolute top-0 left-0 w-full h-0.5 bg-current rounded-full transition-all duration-300 ease-in-out 
                            group-hover:w-3/4 group-[.open]:w-full
                            group-[.open]:top-1/2 group-[.open]:-translate-y-1/2 group-[.open]:rotate-45"></span>
                        
                        <span class="absolute top-1/2 left-0 w-full h-0.5 bg-current rounded-full -translate-y-1/2 transition-all duration-300 ease-in-out 
                            group-[.open]:opacity-0 group-[.open]:translate-x-full"></span>
                        
                        <span class="absolute bottom-0 left-0 w-full h-0.5 bg-current rounded-full transition-all duration-300 ease-in-out 
                            group-hover:w-1/2 group-[.open]:w-full
                            group-[.open]:bottom-1/2 group-[.open]:translate-y-1/2 group-[.open]:-rotate-45"></span> 
                    </div>
                </button>
            </div>
        </div>
    </div>

    <div id="menu-backdrop" class="fixed inset-0 top-16 bg-black/60 backdrop-blur-sm z-30 transition-all duration-300 opacity-0 invisible md:hidden h-screen"></div>

    <div id="mobile-menu" class="absolute top-16 left-0 w-full bg-background-light dark:bg-background-dark border-b border-gray-200 dark:border-border-dark shadow-xl md:hidden z-40 overflow-hidden transition-all duration-500 ease-in-out max-h-0 opacity-0 invisible">
        <div class="flex flex-col p-4 gap-4">
            {links.map(link => (
                <a class="mobile-link block px-4 py-3 text-slate-600 uppercase font-display dark:text-slate-300 hover:text-primary dark:hover:text-white rounded-lg text-3xl font-bold transition-all duration-500 ease-[cubic-bezier(0.34,1.56,0.64,1)] opacity-0 translate-y-8"
                    href={getHref(link.href)}>
                    {link.name}
                </a>
            ))}
        </div>
    </div>
</header>

<script>
    const btn = document.getElementById('mobile-menu-btn');
    const menu = document.getElementById('mobile-menu');
    const backdrop = document.getElementById('menu-backdrop');
    const links = document.querySelectorAll('.mobile-link'); 

    // --- LOGICA MENU MOBILE ---
    const toggleMenu = (show: boolean) => {
        if (!menu || !backdrop || !btn) return;

        if (show) {
            btn.classList.add('open');
        } else {
            btn.classList.remove('open');
        }

        if (show) {
            document.body.classList.add('overflow-hidden');
            menu.classList.remove('max-h-0', 'opacity-0', 'invisible');
            menu.classList.add('max-h-screen', 'opacity-100', 'visible');
            backdrop.classList.remove('opacity-0', 'invisible');
            backdrop.classList.add('opacity-100', 'visible');

            setTimeout(() => {
                links.forEach((link, index) => {
                    const el = link as HTMLElement;
                    el.style.transitionDelay = `${index * 100}ms`;
                    el.classList.remove('opacity-0', 'translate-y-8');
                });
            }, 100);

        } else {
            document.body.classList.remove('overflow-hidden');
            links.forEach((link) => {
                const el = link as HTMLElement;
                el.style.transitionDelay = '0ms';
                el.classList.add('opacity-0', 'translate-y-8');
            });
            menu.classList.remove('max-h-screen', 'opacity-100', 'visible');
            menu.classList.add('max-h-0', 'opacity-0', 'invisible');
            backdrop.classList.remove('opacity-100', 'visible');
            backdrop.classList.add('opacity-0', 'invisible');
        }
    };

    if (btn && menu && backdrop) {
        btn.addEventListener('click', () => {
            const isOpen = menu.classList.contains('visible');
            toggleMenu(!isOpen);
        });

        backdrop.addEventListener('click', () => toggleMenu(false));
    }

    links.forEach(link => {
        link.addEventListener('click', () => toggleMenu(false));
    });

    // --- SCROLL FLUIDO ---
    const navLinks = document.querySelectorAll('a[href^="#"]');
    navLinks.forEach(link => {
        link.addEventListener('click', (e) => {
        e.preventDefault();
        const href = link.getAttribute('href');
        if (!href || href === '#') return;
        const target = document.querySelector(href);
        if (target) {
            const headerOffset = 60; 
            const elementPosition = target.getBoundingClientRect().top;
            const offsetPosition = elementPosition + window.scrollY - headerOffset;
            window.scrollTo({ top: offsetPosition, behavior: 'smooth' });
        }
        });
    });

    // --- PULIZIA URL DOPO NAVIGAZIONE ---
    window.addEventListener('load', () => {
        if (window.location.hash) {
            setTimeout(() => {
                history.replaceState('', document.title, window.location.pathname + window.location.search);
            }, 100);
        }
    });

    // --- MANTENERE LA SEZIONE QUANDO SI CAMBIA LINGUA ---
    const langLinks = document.querySelectorAll('.lang-switch');

    // Funzione che calcola quale sezione sta guardando l'utente al momento
    const getCurrentSection = () => {
        const sections = document.querySelectorAll('section[id]');
        let currentId = '';

        sections.forEach(section => {
            const rect = section.getBoundingClientRect();
            if (rect.top <= 100 && rect.bottom >= 100) {
                currentId = section.getAttribute('id') || '';
            }
        });
        return currentId;
    };

    langLinks.forEach(link => {
        link.addEventListener('click', (e) => {
            // Se c'è un hash nell'URL 
            let hash = window.location.hash;

            // Calcoliamo la sezione visibile se non c'è hash
            if (!hash) {
                const sectionId = getCurrentSection();
                if (sectionId) hash = '#' + sectionId;
            }

            // Se abbiamo trovato una destinazione (hash), navighiamo manualmente
            if (hash) {
                e.preventDefault();
                const target = e.currentTarget as HTMLAnchorElement;
                if (!target.href.includes('#')) {
                    window.location.href = target.href + hash;
                } else {
                    window.location.href = target.href;
                }
            }
        });
    });
</script>