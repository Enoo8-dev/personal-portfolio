---
import { useTranslations } from '../../i18n/utils';
import { personalInfo } from '../../data/business';

interface Props {
    lang: 'en' | 'it';
}

const { lang } = Astro.props;
const t = useTranslations(lang);
const currentYear = new Date().getFullYear();
---

<footer class="w-full py-8 border-t border-gray-200 dark:border-border-dark bg-background-light dark:bg-background-dark">
    <div
        class="flex flex-col md:flex-row items-center justify-between gap-4 max-w-[1200px] mx-auto px-4 sm:px-10">
        <p class="text-slate-500 dark:text-slate-400 text-sm">&copy; {currentYear} {personalInfo.fullName} - {t('footer.piva')}: {personalInfo.p_iva}. {t('footer.rights')}</p>
        <div class="flex items-center gap-6">
            <a class="text-slate-500 dark:text-slate-400 hover:text-primary dark:hover:text-white text-sm transition-colors"
                href="/privacy-policy">Privacy Policy</a>
            <a class="text-slate-500 dark:text-slate-400 hover:text-primary dark:hover:text-white text-sm transition-colors"
                href="/cookie-policy">Cookie Policy</a>
        </div>
    </div>
</footer>