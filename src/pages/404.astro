---
import Layout from "../layouts/Layout.astro";
import { getLangFromUrl, useTranslations } from '../i18n/utils';

const lang = getLangFromUrl(Astro.url);
const t = useTranslations(lang);
---

<Layout title={t('404.title')} lang={lang}>
    <style>
        .cursor-blink {
            animation: blink 1s step-end infinite;
        }
        @keyframes blink {
            50% {
                opacity: 0;
            }
        }
        .scanline {
            width: 100%;
            height: 100px;
            z-index: 10;
            background: linear-gradient(
                0deg,
                rgba(0, 0, 0, 0) 0%,
                rgba(19, 91, 236, 0.2) 50%,
                rgba(0, 0, 0, 0) 100%
            );
            opacity: 0.1;
            position: absolute;
            bottom: 80%;
            animation: scanline 5s linear infinite;
            pointer-events: none;
        }
        @keyframes scanline {
            0% {
                bottom: 100%;
            }
            80% {
                bottom: 100%;
            }
            100% {
                bottom: -100px;
            }
        }
    </style>

    <div
        class="relative flex min-h-screen w-full flex-col overflow-x-hidden"
    >
        
        <main
            class="flex-grow flex flex-col items-center justify-center w-full relative overflow-hidden"
        >
            <div class="scanline"></div>
            <section
                class="w-full max-w-[1200px] px-4 py-12 md:py-24 sm:px-10 flex flex-col items-center justify-center min-h-[calc(100vh-140px)]"
            >
                <div
                    class="w-full max-w-4xl flex flex-col items-center text-center relative z-10"
                >
                    <div
                        class="absolute top-1/2 left-1/2 -translate-x-1/2 -translate-y-1/2 w-[600px] h-[600px] bg-primary/5 rounded-full blur-[100px] -z-10"
                    >
                    </div>
                    <div class="relative mb-8">
                        <h1
                            class="text-[120px] sm:text-[180px] font-black font-display leading-none text-transparent bg-clip-text bg-gradient-to-b from-slate-800 to-slate-900 dark:from-white dark:to-slate-500 opacity-20 dark:opacity-10 absolute top-2 left-1 select-none"
                        >
                            404
                        </h1>
                        <h1
                            class="text-[120px] sm:text-[180px] font-black font-display leading-none text-primary relative z-20 animate-glitch"
                            style="text-shadow: 2px 2px 0px #0ea5e9, -2px -2px 0px #ef4444;"
                        >
                            404
                        </h1>
                        <div
                            class="absolute -right-12 top-0 bg-white dark:bg-surface-dark border border-gray-200 dark:border-border-dark p-3 rounded-lg shadow-xl hidden sm:block rotate-12"
                        >
                            <span
                                class="material-symbols-outlined text-red-500 text-3xl"
                                >bug_report</span
                            >
                        </div>
                    </div>
                    <div
                        class="w-full max-w-2xl bg-white dark:bg-[#0d121c] border border-gray-200 dark:border-border-dark rounded-xl shadow-2xl overflow-hidden mb-10 text-left"
                    >
                        <div
                            class="flex items-center gap-2 px-4 py-3 border-b border-gray-200 dark:border-border-dark bg-gray-50 dark:bg-[#111722]"
                        >
                            <div class="flex gap-2">
                                <div class="w-3 h-3 rounded-full bg-red-500"></div>
                                <div class="w-3 h-3 rounded-full bg-yellow-500"></div>
                                <div class="w-3 h-3 rounded-full bg-green-500"></div>
                            </div>
                            <div
                                class="flex-1 text-center text-lg font-mono text-slate-500 dark:text-slate-400"
                            >
                                console — zsh — 80x24
                            </div>
                        </div>
                        <div
                            class="p-6 font-mono text-sm sm:text-base bg-white dark:bg-[#0d121c] text-slate-700 dark:text-slate-300"
                        >
                            <p class="mb-2">
                                <span class="text-green-500">➜</span>
                                <span class="text-blue-500">~</span>
                                <span class="text-slate-400">wget</span> https://beninifederico.it{Astro.url.pathname}
                            </p>
                            <p class="mb-2">{t('404.console.connecting')}</p>
                            <p class="mb-2 text-red-500">
                                {t('404.console.error')}
                            </p>
                            <p class="mb-4 text-slate-500">
                                {t('404.console.comment')}
                            </p>
                            <p class="mb-2">
                                <span class="text-green-500">➜</span>
                                <span class="text-blue-500">~</span>
                                <span
                                    class="cursor-blink inline-block w-2.5 h-5 bg-primary align-middle ml-1"
                                ></span>
                            </p>
                        </div>
                    </div>
                    <h2
                        class="text-2xl sm:text-3xl font-bold font-display text-slate-900 dark:text-white mb-4"
                    >
                        {t('404.heading')}
                    </h2>
                    <p
                        class="text-slate-600 dark:text-slate-400 max-w-lg text-center mb-10 text-lg"
                    >
                        {t('404.description')}
                    </p>
                    <div
                        class="flex flex-col sm:flex-row gap-4 w-full sm:w-auto"
                    >
                        <a
                            class="flex items-center justify-center gap-2 w-full sm:w-auto px-8 py-3.5 bg-primary hover:bg-primary/90 text-white rounded-lg font-bold transition-all shadow-lg shadow-primary/25 hover:shadow-primary/40 group"
                            href={lang === 'it' ? '/it' : '/'}
                        >
                            <span
                                class="material-symbols-outlined text-xl group-hover:-translate-x-1 transition-transform"
                                >arrow_back</span
                            >
                            {t('404.back')}
                        </a>
                        <a
                            class="flex items-center justify-center gap-2 w-full sm:w-auto px-8 py-3.5 bg-white dark:bg-surface-dark border border-gray-200 dark:border-border-dark hover:border-primary/50 text-slate-900 dark:text-white rounded-lg font-bold transition-all hover:shadow-lg"
                            href={lang === 'it' ? '/it#contact' : '/#contact'}
                        >
                            <span
                                class="material-symbols-outlined text-xl text-primary"
                                >mail</span
                            >
                            {t('404.contact')}
                        </a>
                    </div>
                </div>
            </section>
       </main>
</Layout>
        
        